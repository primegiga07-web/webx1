# Django Configurations
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Database Configuration (Supabase PostgreSQL URL)
# Example: postgres://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=postgres://user:password@host:port/dbname

# Sharding Configurations (Required for Shard Instances only)
SHARD_PREFIX=RW100
SHARD_SECRET_KEY=your-high-entropy-inter-shard-auth-token-here

# Shards Registry JSON Map (Required for Gateway and Shards)
# Map prefixes to their deployed API Base URLs
SHARDS_DIRECTORY={"RW100": "https://api-rw100.vercel.app", "RW200": "https://api-rw200.vercel.app"}

# Django Email Configurations (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contact.monobuiltz@gmail.com
EMAIL_HOST_PASSWORD=qmclzvesnjqduubu
DEFAULT_FROM_EMAIL=WebX Support <contact.monobuiltz@gmail.com>
